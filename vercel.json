{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/flights", "dest": "/api/flights.py" },
    { "src": "/api/overview", "dest": "/api/overview.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
